<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" 
          xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.pokemontcg.controller.SearchController">
    <content>
        <VBox spacing="30.0" styleClass="content-area">
            <children>
                <!-- Título e Barra de Busca Central -->
                <VBox alignment="CENTER" spacing="15">
                    <children>
                        <Label text="Search Pokémon Cards" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #263238;" />
                        <Label text="Explore data from 10k+ cards across all historic expansions." style="-fx-text-fill: #78909C; -fx-font-size: 14;" />
                        
                        <HBox alignment="CENTER" spacing="15">
                            <VBox.margin><Insets top="20" /></VBox.margin>
                            <children>
                                <TextField fx:id="txtSearch" promptText="Search name (e.g. Charizard)..." 
                                           prefWidth="500" prefHeight="50" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #ECEFF1; -fx-border-radius: 12; -fx-padding: 0 20; -fx-font-size: 16;" />
                                <Button onAction="#handleSearch" text="SEARCH" 
                                        prefHeight="50" style="-fx-background-color: #C2185B; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 0 40; -fx-background-radius: 12; -fx-cursor: hand;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Separator style="-fx-opacity: 0.5;" />

                <!-- Indicador de Status/Loading -->
                <Label fx:id="lblStatus" text="Ready to search..." style="-fx-text-fill: #78909C; -fx-font-size: 12;" />

                <!-- Grade de Resultados -->
                <FlowPane fx:id="flowResults" hgap="25" vgap="40" alignment="CENTER" 
                          prefWrapLength="1000" minHeight="500">
                    <padding>
                        <Insets top="20" right="20" bottom="50" left="20" />
                    </padding>
                    <!-- Os componentes card_item.fxml serão injetados aqui via controlador -->
                </FlowPane>
            </children>
        </VBox>
    </content>
</ScrollPane>