<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pokemontcg.controller.SearchController">
    <content>
        <VBox spacing="30" styleClass="content-area">
            <children>
                <!-- Título e Descrição -->
                <VBox spacing="5">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <FontIcon iconLiteral="fas-search" iconSize="28" styleClass="card-icon-primary" />
                                <Label text="PROCURAR CARTAS" styleClass="section-title-xl" />
                            </children>
                        </HBox>
                        <Label text="Acesse o banco de dados global da Pokémon Company e filtre por raridade, tipo ou série." styleClass="section-subtitle" />
                    </children>
                </VBox>
                
                <!-- Barra de Busca Principal -->
                <HBox spacing="15">
                    <children>
                        <TextField fx:id="txtSearch" promptText="Ex: Charizard, Lugia, Pikachu..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleSearch" styleClass="btn-primary-md" text="BUSCAR">
                            <graphic>
                                <FontIcon iconLiteral="fas-search" iconSize="16" style="-fx-icon-color: -app-text-on-primary;" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
                
                <!-- Filtros Rápidos -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5">
                            <children>
                                <Label text="TIPO" styleClass="app-subtitle" />
                                <ComboBox fx:id="comboType" prefWidth="180" promptText="Todos os Tipos" styleClass="btn-outline" />
                            </children>
                        </VBox>
                        
                        <VBox spacing="5">
                            <children>
                                <Label text="RARIDADE" styleClass="app-subtitle" />
                                <ComboBox fx:id="comboRarity" prefWidth="180" promptText="Todas as Raridades" styleClass="btn-outline" />
                            </children>
                        </VBox>
                        
                        <VBox spacing="5">
                            <children>
                                <Label text="SÉRIE" styleClass="app-subtitle" />
                                <ComboBox fx:id="comboSet" prefWidth="180" promptText="Todas as Séries" styleClass="btn-outline" />
                            </children>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <Button styleClass="btn-danger-text" text="Limpar Filtros">
                            <graphic>
                                <FontIcon iconLiteral="fas-filter" iconSize="14" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>

                <Separator styleClass="separator-light" />
                
                <!-- Grade de Resultados -->
                <FlowPane fx:id="flowResults" hgap="25" vgap="40" alignment="CENTER" prefWrapLength="1000">
                    <padding>
                        <Insets top="10" right="10" bottom="30" left="10" />
                    </padding>
                    <!-- Os componentes card_item.fxml serão injetados aqui via controlador -->
                </FlowPane>
            </children>
        </VBox>
    </content>
</ScrollPane>