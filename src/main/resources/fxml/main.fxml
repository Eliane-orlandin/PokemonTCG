<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainLayout" prefHeight="700.0" prefWidth="1000.0" 
            stylesheets="@../css/styles.css" styleClass="root-pane" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.pokemontcg.controller.MainController">
    
    <!-- Barra Lateral (Sidebar) -->
    <left>
        <VBox prefWidth="240.0" spacing="10.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
            </padding>
            <children>
                <!-- Título/Logo do App -->
                <Label styleClass="app-title" text="POKÉMON">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label styleClass="app-subtitle" text="TCG Catalog" />
                
                <VBox spacing="15.0" styleClass="menu-container">
                    <VBox.margin>
                        <Insets top="40.0" />
                    </VBox.margin>
                    <children>
                        <!-- Botões do Menu -->
                        <Button fx:id="btnSearch" alignment="BASELINE_LEFT" onAction="#showSearch" 
                                prefHeight="50.0" prefWidth="200.0" styleClass="menu-button" text="🔍  Buscar Cards" />
                        
                        <Button fx:id="btnCatalog" alignment="BASELINE_LEFT" onAction="#showCatalog" 
                                prefHeight="50.0" prefWidth="200.0" styleClass="menu-button" text="🗃️  Meu Catálogo" />
                        
                        <Button fx:id="btnExport" alignment="BASELINE_LEFT" onAction="#showExport" 
                                prefHeight="50.0" prefWidth="200.0" styleClass="menu-button" text="📄  Exportar Tudo" />
                    </children>
                </VBox>
                
                <VBox VBox.vgrow="ALWAYS" /> <!-- Espaçador para empurrar o rodapé -->
                
                <!-- Rodapé da Sidebar -->
                <Label styleClass="version-label" text="v1.0.0" />
            </children>
        </VBox>
    </left>
    
    <!-- Área Central: Onde as telas de Busca e Catálogo serão carregadas -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- Inicialmente vazio. Será preenchido via MainController -->
        </StackPane>
    </center>
    
</BorderPane>
