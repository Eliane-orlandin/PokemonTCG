<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="mainLayout" prefHeight="700.0" prefWidth="1200.0" 
            stylesheets="@../css/styles.css" styleClass="root-pane" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.pokemontcg.controller.MainController">
    
    <!-- BARRA LATERAL (Sidebar) -->
    <left>
        <VBox prefWidth="250" styleClass="sidebar">
            <children>
                <!-- Logo e Branding -->
                <VBox alignment="CENTER" styleClass="app-logo-container">
                    <children>
                        <Label text="▣" styleClass="app-logo-icon" />
                        <Label text="THE GLASS TRAINER" styleClass="app-title" />
                        <Label text="CODEX DIGITAL" styleClass="app-subtitle" />
                    </children>
                </VBox>
                
                <!-- Menu de Navegação -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnHome" onAction="#handleNavigateHome" maxWidth="Infinity" styleClass="menu-button-active">
                            <graphic>
                                <FontIcon iconLiteral="fas-home" iconSize="18" styleClass="ikonli-font-icon" />
                            </graphic>
                            <text>Início</text>
                            <VBox.margin><Insets left="15" right="15"/></VBox.margin>
                        </Button>
                        
                        <Button fx:id="btnSearch" onAction="#handleNavigateSearch" maxWidth="Infinity" styleClass="menu-button">
                            <graphic>
                                <FontIcon iconLiteral="fas-search" iconSize="18" styleClass="ikonli-font-icon" />
                            </graphic>
                            <text>Buscar Cartas</text>
                            <VBox.margin><Insets left="15" right="15"/></VBox.margin>
                        </Button>
                        
                        <Button fx:id="btnCatalog" onAction="#handleNavigateCatalog" maxWidth="Infinity" styleClass="menu-button">
                            <graphic>
                                <FontIcon iconLiteral="fas-th-large" iconSize="18" styleClass="ikonli-font-icon" />
                            </graphic>
                            <text>Minha Coleção</text>
                            <VBox.margin><Insets left="15" right="15"/></VBox.margin>
                        </Button>
                        
                        <Button fx:id="btnExport" onAction="#handleNavigateExport" maxWidth="Infinity" styleClass="menu-button">
                            <graphic>
                                <FontIcon iconLiteral="fas-file-export" iconSize="18" styleClass="ikonli-font-icon" />
                            </graphic>
                            <text>Exportar</text>
                            <VBox.margin><Insets left="15" right="15"/></VBox.margin>
                        </Button>
                    </children>
                </VBox>
                
                <!-- Rodapé da Sidebar (User Profile) -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="sidebar-footer">
                    <children>
                        <Label text="👤" styleClass="header-icon-profile" />
                        <VBox>
                            <children>
                                <Label text="Ash Ketchum" styleClass="row-card-name" />
                                <Label text="Mestre Pokémon" styleClass="app-subtitle" />
                            </children>
                        </VBox>
                    </children>
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                </HBox>
            </children>
        </VBox>
    </left>
    
    <!-- ÁREA CENTRAL -->
    <center>
        <VBox>
            <children>
                <!-- Cabeçalho (Header) -->
                <HBox alignment="CENTER_LEFT" styleClass="header-pane">
                    <children>
                        <Label styleClass="header-title" text="PokéCatálogo TCG" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="20">
                            <children>
                                <TextField promptText="Pesquisar no acervo..." styleClass="search-field" prefWidth="250" />
                                <Label text="🔔" styleClass="header-icon" />
                                <Label text="⚙" styleClass="header-icon" />
                                <Label text="👤" styleClass="header-icon-profile" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
                
                <!-- Conteúdo Dinâmico -->
                <StackPane fx:id="contentArea" styleClass="content-area" VBox.vgrow="ALWAYS">
                    <!-- As telas serão injetadas aqui -->
                </StackPane>
            </children>
        </VBox>
    </center>
    
</BorderPane>
