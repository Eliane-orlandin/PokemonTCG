<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" 
          xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.pokemontcg.controller.CatalogController">
    <content>
        <VBox spacing="25.0" styleClass="content-area">
            <children>
                <!-- (...) - omitindo o header ja existente para brevidade no replacement se possivel, mas vou substituir o bloco todo -->
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5">
                            <Label text="Collection Management" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #263238;" />
                            <Label text="Curating your digital library" style="-fx-text-fill: #78909C; -fx-font-size: 14;" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="10" alignment="CENTER">
                            <children>
                                <Button text="Filter" style="-fx-background-color: white; -fx-border-color: #ECEFF1; -fx-border-radius: 8; -fx-padding: 8 20;" />
                                <Button text="Sort By" style="-fx-background-color: white; -fx-border-color: #ECEFF1; -fx-border-radius: 8; -fx-padding: 8 20;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #F8F9FB; -fx-background-radius: 12; -fx-padding: 15;">
                    <children>
                        <Label text="EXPORTS" style="-fx-text-fill: #C2185B; -fx-font-weight: bold; -fx-font-size: 11;" />
                        <Button text="Export as JSON" style="-fx-background-color: #C2185B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15;" />
                        <Button text="Export as CSV" style="-fx-background-color: #ECEFF1; -fx-text-fill: #263238; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="🗑 Bulk Delete" style="-fx-background-color: transparent; -fx-text-fill: #EF5350;" />
                    </children>
                </HBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 0);">
                    <children>
                        <HBox spacing="20" style="-fx-padding: 15 20; -fx-border-color: #ECEFF1; -fx-border-width: 0 0 1 0;">
                            <children>
                                <CheckBox />
                                <Label text="CARD NAME" prefWidth="250" style="-fx-text-fill: #78909C; -fx-font-weight: bold; -fx-font-size: 11;" />
                                <Label text="SET" prefWidth="150" style="-fx-text-fill: #78909C; -fx-font-weight: bold; -fx-font-size: 11;" />
                                <Label text="TYPE" prefWidth="100" style="-fx-text-fill: #78909C; -fx-font-weight: bold; -fx-font-size: 11;" />
                                <Label text="RARITY" prefWidth="120" style="-fx-text-fill: #78909C; -fx-font-weight: bold; -fx-font-size: 11;" />
                                <Label text="QTY" prefWidth="40" style="-fx-text-fill: #78909C; -fx-font-weight: bold; -fx-font-size: 11;" />
                                <Label text="ACTIONS" style="-fx-text-fill: #78909C; -fx-font-weight: bold; -fx-font-size: 11;" />
                            </children>
                        </HBox>
                        
                        <!-- Container para Linhas Dinâmicas do Banco de Dados -->
                        <VBox fx:id="vboxCatalogRows" spacing="0">
                            <!-- Injetado dinamicamente -->
                        </VBox>
                    </children>
                </VBox>

                <!-- Footer Summary Cards -->
                <HBox spacing="25">
                    <children>
                        <VBox prefWidth="350" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-padding: 20;">
                            <children>
                                <Label text="TOTAL VALUE" style="-fx-text-fill: #78909C; -fx-font-size: 11; -fx-font-weight: bold;" />
                                <Label text="$2,840" style="-fx-font-size: 32; -fx-font-weight: 900; -fx-text-fill: #263238;" />
                                <Label text="Based on current market trends." style="-fx-font-size: 11; -fx-text-fill: #78909C;" />
                            </children>
                        </VBox>
                        
                        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #F3E5F5; -fx-background-radius: 20; -fx-padding: 20;">
                            <children>
                                <Label text="COLLECTION MIX" style="-fx-text-fill: #C2185B; -fx-font-size: 11; -fx-font-weight: bold;" />
                                <HBox spacing="10" alignment="BOTTOM_LEFT" prefHeight="60">
                                    <Region prefHeight="30" prefWidth="30" style="-fx-background-color: #C2185B; -fx-background-radius: 5 5 0 0;" />
                                    <Region prefHeight="50" prefWidth="30" style="-fx-background-color: #C2185B; -fx-background-radius: 5 5 0 0;" />
                                    <Region prefHeight="20" prefWidth="30" style="-fx-background-color: #C2185B; -fx-background-radius: 5 5 0 0;" />
                                    <Region prefHeight="40" prefWidth="30" style="-fx-background-color: #C2185B; -fx-background-radius: 5 5 0 0;" />
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </content>
</ScrollPane>