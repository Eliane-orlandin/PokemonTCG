<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pokemontcg.controller.CatalogController">
    <content>
        <VBox spacing="30" styleClass="content-area">
            <children>
                <!-- Título e Estatísticas -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <FontIcon iconLiteral="fas-th-large" iconSize="26" styleClass="card-icon-primary" />
                                <Label text="MINHA COLEÇÃO" styleClass="section-title-xl" />
                            </children>
                        </HBox>
                        <Label fx:id="lblCatalogStats" text="Total de Cartas: 0 | Valor Estimado: $0.00" styleClass="section-subtitle" />
                    </children>
                </VBox>

                <!-- Barra de Busca Local -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <ComboBox fx:id="comboCategoryLocal" maxHeight="48" minHeight="48" prefWidth="150" promptText="Categoria" styleClass="btn-outline" />
                        <TextField fx:id="txtSearchLocal" maxHeight="48" minHeight="48" promptText="Procurar na minha coleção..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                        <Button maxHeight="48" minHeight="48" onAction="#handleLocalSearch" styleClass="btn-primary" text="BUSCAR">
                            <graphic>
                                <FontIcon iconLiteral="fas-search" iconSize="16" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
                
                <!-- Área da Tabela Estilizada -->
                <VBox VBox.vgrow="ALWAYS" styleClass="table-container">
                    <children>
                        <HBox fx:id="hboxTableHeader" styleClass="table-header" spacing="15">
                            <children>
                                <Label prefWidth="250" text="CARD / NOME" styleClass="table-column-label" />
                                <Label prefWidth="120" text="ESTÁGIO" styleClass="table-column-label" />
                                <Label prefWidth="100" text="TIPO" styleClass="table-column-label" alignment="CENTER" />
                                <Label prefWidth="150" text="RARIDADE" styleClass="table-column-label" />
                                <Label prefWidth="60" text="QTD" styleClass="table-column-label" alignment="CENTER" />
                                <Label prefWidth="100" text="AÇÕES" styleClass="table-column-label" alignment="CENTER" />
                            </children>
                        </HBox>
                        
                        <!-- Lista de Cards (dinâmica) -->
                        <VBox fx:id="vboxCatalog" spacing="1">
                        </VBox>

                        <!-- Paginação -->
                        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20 0 0 0;">
                            <children>
                                <Button fx:id="btnPrevPage" styleClass="btn-outline" onAction="#handlePrevPage">
                                    <graphic><FontIcon iconLiteral="fas-chevron-left"/></graphic>
                                </Button>
                                <Label fx:id="lblPagination" text="Página 1 de 1" styleClass="section-subtitle" />
                                <Button fx:id="btnNextPage" styleClass="btn-outline" onAction="#handleNextPage">
                                    <graphic><FontIcon iconLiteral="fas-chevron-right"/></graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>