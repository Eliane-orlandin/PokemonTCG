<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Componente individual de carta: exibido nos resultados de busca -->
<VBox spacing="10" styleClass="card-item-container" fx:id="cardRoot" onMouseClicked="#handleShowDetail" cursor="HAND"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pokemontcg.controller.CardItemController">
    <children>
        <!-- Container da Imagem com bordas arredondadas -->
        <StackPane fx:id="imageContainer" prefWidth="180" prefHeight="250" styleClass="card-image-placeholder">
            <children>
                <ImageView fx:id="cardImage" fitWidth="180" fitHeight="250" preserveRatio="true" />
            </children>
        </StackPane>
        
        <!-- Detalhes da Carta: nome, set ID e botão de adicionar -->
        <HBox alignment="CENTER_LEFT">
            <VBox HBox.hgrow="ALWAYS">
                <Label fx:id="lblSetId" text="SET ID • 000/000" styleClass="card-set-id" />
                <Label fx:id="lblName" text="Pokémon Name" styleClass="card-name" />
            </VBox>
            <!-- Botão redondo "+" para adicionar à coleção -->
            <Button onAction="#handleAddToCollection" styleClass="btn-add-card">
                <graphic>
                    <FontIcon iconLiteral="fas-plus" iconSize="12" style="-fx-icon-color: white;" />
                </graphic>
            </Button>
        </HBox>
        
        <!-- Badge de tipo e raridade -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <children>
                <Label fx:id="lblType" text="TYPE" styleClass="type-badge-pill" />
                <Label fx:id="lblRarity" text="Rarity" styleClass="card-rarity" />
            </children>
        </HBox>
    </children>
</VBox>
