<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Componente de linha do catálogo: exibe uma carta salva na coleção pessoal -->
<HBox fx:id="rootContainer" spacing="15" alignment="CENTER_LEFT" styleClass="table-row"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pokemontcg.controller.CatalogRowController"
      onMouseClicked="#handleShowDetail">
    <children>
        <!-- Info Principal com Miniatura da carta -->
        <HBox spacing="12" alignment="CENTER_LEFT" prefWidth="250">
            <children>
                <StackPane styleClass="row-thumbnail-container" prefWidth="35" prefHeight="48">
                    <children>
                        <ImageView fx:id="imgMini" fitWidth="35" fitHeight="48" preserveRatio="true" />
                    </children>
                </StackPane>
                <VBox alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="lblName" text="Card Name" styleClass="row-card-name" />
                        <Label fx:id="lblSetId" text="SET • ID" styleClass="card-set-id" />
                    </children>
                </VBox>
            </children>
        </HBox>
        
        <!-- Estágio da carta -->
        <Label fx:id="lblStage" text="Básico" prefWidth="120" styleClass="row-set-name" />
        
        <!-- Badge de Tipo -->
        <HBox prefWidth="100" alignment="CENTER">
            <children>
                <Label fx:id="lblType" text="FIRE" styleClass="type-badge-pill" alignment="CENTER" prefWidth="90" />
            </children>
        </HBox>
        
        <!-- Raridade -->
        <Label fx:id="lblRarity" text="✪ Ultra Rare" prefWidth="150" styleClass="row-rarity" />
        
        <!-- Quantidade -->
        <Label fx:id="lblQty" text="01" prefWidth="60" styleClass="row-quantity" alignment="CENTER" />
        
        <!-- Ações (Deletar) -->
        <HBox alignment="CENTER" prefWidth="100" spacing="10">
            <children>
                <FontIcon iconLiteral="fas-trash" iconSize="16" onMouseClicked="#handleDelete" styleClass="btn-delete-icon" />
            </children>
        </HBox>
    </children>
</HBox>
